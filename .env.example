# Claude API key - get from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# Model to use (claude-sonnet-4 is the recommended default)
# Alternatives: claude-opus-4-5 (smarter, pricier), claude-haiku-4-5 (faster, cheaper)
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# AWS credentials — if not set, falls back to ~/.aws/credentials via boto3 default chain
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1

# Path to your Red Hat pull secret (download from https://console.redhat.com/openshift/install)
PULL_SECRET_PATH=~/.ocp-agent/pull-secret.json

# Path to the openshift-install binary (download from https://mirror.openshift.com/pub/openshift-v4/clients/ocp/)
# Leave empty if it's on your PATH
OPENSHIFT_INSTALL_PATH=

# Base directory for all cluster installations
CLUSTERS_DIR=~/.ocp-agent/clusters

# Web UI port (default 8765)
WEB_PORT=8765

# Terminal UI theme: "light" or "dark"
TERMINAL_THEME=dark
